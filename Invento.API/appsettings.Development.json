{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost\\SQLEXPRESS;Database=InventoDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },

  "Redis": {
    "ConnectionString": "localhost:6379"
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },

  "Hangfire": {
    "RegisterRecurringJobs": true
  },

  "AllowedHosts": "localhost",

  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],

    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [CorrelationId:{CorrelationId}] [TenantId:{TenantId}] [UserId:{UserId}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/invento-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "shared": true,
          "flushToDiskInterval": "00:00:01",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [CorrelationId:{CorrelationId}] [TenantId:{TenantId}] [UserId:{UserId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}