{
  "JwtSettings": {
    "Issuer": "InventoAPI",
    "Audience": "InventoClient",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },

  "EmailSettings": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "connectInvento",
    "FromEmail": "connectinvento@gmail.com",
    "FromName": "Invento",
    "EnableSsl": true
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Hangfire": "Information"
      }
    },

    "Enrich": [
      "FromLogContext"
    ],

    "Properties": {
      "Application": "Invento.API"
    }
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "HttpsRedirection": {
    "Enabled": true
  },

  "Cors": {
    "AllowedOrigins": []
  },

  "Hangfire": {
    "RegisterRecurringJobs": false
  },

  "AllowedHosts": "localhost"
}