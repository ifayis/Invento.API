# ============================================================
# INVENTO-SPECIFIC RULES
# ============================================================

# ------------------------------------------------------------
# Invento Serilog runtime logs
# ------------------------------------------------------------
Logs/
**/Logs/
**/[Ll]ogs/
invento-*.log
**/invento-*.log

# ------------------------------------------------------------
# Local environment variable files
# ------------------------------------------------------------
.env
.env.*
!.env.example

# ------------------------------------------------------------
# Local-only ASP.NET configuration overrides
# ------------------------------------------------------------
appsettings.Local.json
appsettings.*.Local.json
**/appsettings.Local.json
**/appsettings.*.Local.json

# ------------------------------------------------------------
# Local secret files
# ------------------------------------------------------------
secrets.json
**/secrets.json

# ------------------------------------------------------------
# Redis local persistence
# ------------------------------------------------------------
dump.rdb
**/dump.rdb
appendonly.aof
**/appendonly.aof
appendonlydir/
**/appendonlydir/

# ------------------------------------------------------------
# Redis local temporary/runtime files
# ------------------------------------------------------------
redis.pid
**/redis.pid

# ------------------------------------------------------------
# Local database backups
# ------------------------------------------------------------
*.bak
*.bacpac

# ------------------------------------------------------------
# Local temporary files
# ------------------------------------------------------------
*.temp
*.swp

# ------------------------------------------------------------
# Docker local developer overrides
# Keep main Docker files trackable later
# ------------------------------------------------------------
docker-compose.override.yml
**/docker-compose.override.yml

# ------------------------------------------------------------
# AWS local tooling state
# ------------------------------------------------------------
.aws-sam/
samconfig.local.toml

# ------------------------------------------------------------
# Terraform local state
# Only relevant if Terraform is added later
# ------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Do not ignore Terraform lock file:
# .terraform.lock.hcl should normally be committed

# ------------------------------------------------------------
# Local IDE folders
# ------------------------------------------------------------
.idea/

# VS Code:
# Ignored for now because Invento does not currently rely on
# shared workspace configuration.
.vscode/

# ------------------------------------------------------------
# OS-generated files
# ------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini